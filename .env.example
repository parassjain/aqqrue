# LLM Configuration (via LiteLLM)
# Supports: gpt-4o, gpt-4.1, claude-sonnet-4-20250514, gemini/gemini-2.0-flash, ollama/llama3, etc.
MODEL_NAME=gpt-4o
API_KEY=your-api-key-here

# Optional: Override base URL for self-hosted models
# API_BASE=http://localhost:11434

# Sandbox Configuration
SANDBOX_TIMEOUT=30
SANDBOX_MEMORY_LIMIT=512m

# Session Configuration
SESSION_DATA_DIR=data/sessions
MAX_RETRIES=3
